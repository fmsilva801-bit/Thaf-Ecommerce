{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "public/**",
          "static/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/styles.css",
      "dest": "/static/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "/static/app.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
